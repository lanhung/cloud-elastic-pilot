# E02 Node provisioning / warm-pool pilot. Copy to node-warm-pool.env and
# replace every real-environment placeholder before running --check-only.

# -------------------- safety and ACK target --------------------
CONFIRM_KUBE_CONTEXT="no"
CONFIRM_E02_POOL_MUTATION="no"
REQUIRE_CLEAN_GIT="true"
EXPECTED_API_SERVER_SUBSTRING="replace-with-ack-api-host-fragment"
KUBECONFIG_PATH="$HOME/.kube/config"
KUBE_CONTEXT=""
CLUSTER_ID="ack-e02-pilot"
HOOKE_SYSTEM_NAMESPACE="hooke-system"
ARTIFACT_ROOT="artifacts"

# -------------------- paired pilot design --------------------
# Five paired blocks produce five cold-node and five warm-node runs. Within
# each block the two variants are randomly ordered using this frozen seed.
E02_PILOT_REPETITIONS="5"
E02_RANDOM_SEED="20260722"
E02_EXPECTED_INSTANCE_TYPE="ecs.c7.large"
E02_EXPECTED_ZONE="cn-example-a"

# -------------------- dedicated elastic node pool --------------------
# This pool must carry no business workloads. Before min=0, the orchestrator
# permits only DaemonSet/static Pods on its selected Node and otherwise fails.
E02_NODE_POOL_ID="replace-with-nodepool-id"
E02_NODE_POOL_NAME="hooke-e02-dedicated-pool"
E02_NODE_POOL_RESOURCE_GROUP_ID="rg-replace-with-exact-resource-group-id"
ELASTIC_NODE_SELECTOR_KEY="node.alibabacloud.com/nodepool-id"
ELASTIC_NODE_SELECTOR_VALUE="replace-with-nodepool-id"
ELASTIC_TAINT_KEY="hooke.io/experiment"
ELASTIC_TAINT_VALUE="elastic"
ELASTIC_TAINT_EFFECT="NoSchedule"

# The built-in adapter uses Alibaba Cloud CLI and the ACK node-pool APIs. Keep
# credentials in a CLI profile or RAM role, never in this file.
E02_NODE_POOL_CONTROL_HOOK="scripts/ack-node-pool-control.sh"
ALIYUN_CLI_PROFILE="default"
ALIYUN_CLI_REGION="cn-example"
E02_ACK_CONTROL_TIMEOUT_SECONDS="120"
E02_ACK_CONTROL_POLL_SECONDS="2"
E02_ACK_STABILITY_POLLS="3"
E02_POOL_STATE_TIMEOUT_SECONDS="2400"
E02_POOL_POLL_SECONDS="15"
E02_WARM_STABILITY_SECONDS="30"
E02_RESTORE_STABILITY_SECONDS="30"
E02_NODE_POOL_HOOK_TIMEOUT_SECONDS="600"
E02_CHILD_CLEANUP_TIMEOUT_SECONDS="180"
E02_CHILD_RUN_TIMEOUT_SECONDS="3600"
E02_CACHE_HOOK_TIMEOUT_SECONDS="300"

# A warm node is accepted only after a matching CNI Pod is Running and Ready.
# Freeze the selector that is actually present in the target ACK cluster.
E02_REQUIRE_CNI_READY="true"
E02_CNI_NAMESPACE="kube-system"
E02_CNI_POD_SELECTOR="app=flannel"

# -------------------- frozen workload and image --------------------
# Reuse the E01 small image only when the E02 preflight proves that its build
# commit is an ancestor and all smoke-app image inputs are unchanged.
E02_IMAGE_METADATA_FILE="dist/e01-images.env"
E02_IMAGE="registry.example.com/hooke/smoke-small@sha256:replace-with-64-hex-characters"
E02_SMOKE_COMMAND_JSON='["/smoke-app"]'
E02_STARTUP_WORK_MIB="0"
E02_CPU_REQUEST="500m"
E02_CPU_LIMIT="1000m"
E02_MEMORY_REQUEST="256Mi"
E02_MEMORY_LIMIT="512Mi"
CONFIRM_NEW_NODE_COLD_SOURCE="no"

# log mode imports source timestamps from container stdout. sdk mode requires
# a Pod-routable ingester URL, non-loopback bind address, and auth token.
E02_APP_EVENT_MODE="log"
E02_INGESTER_REACHABLE_URL=""
INGESTER_BIND_ADDRESS="127.0.0.1"
INGESTER_PORT="18080"
CONTROLLER_METRICS_PORT="18081"
HOOKE_AUTH_TOKEN=""

# -------------------- exact event and cache hooks --------------------
CACHE_RESET_HOOK="scripts/e01-cache-hook.py"
CACHE_VERIFY_HOOK="scripts/e01-cache-hook.py"
ACK_EVENTS_EXPORT_HOOK="scripts/export-goatscaler-events.py"
RUNTIME_EVENTS_EXPORT_HOOK="scripts/export-runtime-journal-events.py"
ACK_ADAPTER_CONFIG="configs/ack-adapter.yaml"

# Both variants require exact sandbox boundaries. Stock ACK info journals do
# not expose a separate UID-addressable CNI start/end interval, so keep the
# CNI-substage Gate false unless a real source is configured.
E02_REQUIRE_CNI_SUBSTAGE="false"

# The helper image must already be pullable on the elastic pool and contain
# nsenter. The existing cache/runtime hooks read these E01_* variable names.
E01_HOST_HELPER_IMAGE="registry.example.com/ops/host-helper:immutable-version"
E01_CACHE_HOOK_TIMEOUT_SECONDS="120"
E01_CACHE_GC_WAIT_SECONDS="30"
E01_RUNTIME_HOOK_TIMEOUT_SECONDS="120"

# GOATScaler control-plane log export for cold-node runs.
ACK_SLS_REGION="cn-example"
ACK_SLS_PROJECT="k8s-log-replace-with-cluster-id"
ACK_SLS_LOGSTORE="ack-goatscaler-replace-with-cluster-id"
ACK_SLS_MAX_WAIT_SECONDS="30"

# -------------------- child-run timeouts and local services --------------------
NODE_SCALE_TIMEOUT="20m"
E02_APP_ROLLOUT_TIMEOUT="5m"
CONTROLLER_WARMUP_SECONDS="5"
EVENT_SETTLE_SECONDS="5"
ENABLE_HTTP_CHECK="true"
SKIP_BUILD="false"
GOPROXY=""

MYSQL_MODE="docker"
MYSQL_DOCKER_IMAGE="mysql:8.4"
MYSQL_CONTAINER_NAME="hooke-e02-mysql"
MYSQL_VOLUME_NAME="hooke-e02-mysql-data"
MYSQL_HOST_PORT="13306"
MYSQL_DATABASE="hooke"
MYSQL_USER="hooke"
MYSQL_PASSWORD="hooke"
MYSQL_ROOT_PASSWORD="root"
MYSQL_DSN=""
MYSQL_CLI_HOST=""
MYSQL_CLI_PORT="3306"
MYSQL_CLI_USER=""
MYSQL_CLI_PASSWORD=""
RESET_MYSQL="false"
STOP_MYSQL_ON_EXIT="false"

# Each child run uses an isolated namespace and deletes only its own workload.
CLEANUP_K8S_ON_SUCCESS="true"
CLEANUP_K8S_ON_ERROR="false"
REQUIRE_EMPTY_EXPERIMENT_NAMESPACE="true"
UNIQUE_EXPERIMENT_NAMESPACE="true"
UNIQUE_RESOURCE_NAMES="true"
DELETE_EXPERIMENT_NAMESPACE="true"
