# E01 four-layer baseline pilot. Copy to configs/four-layer-baseline.env and
# fill every required real-environment value before running check-only.

CONFIRM_KUBE_CONTEXT="no"
REQUIRE_CLEAN_GIT="true"
EXPECTED_API_SERVER_SUBSTRING=""
KUBECONFIG_PATH="$HOME/.kube/config"
KUBE_CONTEXT=""
CLUSTER_ID="ack-e01-pilot"

E01_PILOT_REPETITIONS="5"
E01_RANDOM_SEED="20260721"
E01_REPLICAS="1"
SLO_SECONDS="30"
ARTIFACT_ROOT="artifacts"

# Both images must contain /smoke-app and be pinned to distinct same-region ACR
# digests. Build them with scripts/build-e01-images.sh; its deterministic,
# incompressible padding changes transfer size without changing app behavior.
# Defaults are 64 MiB padding for small and 512 MiB for large. The metadata file
# is produced by make e01-images-push and is checked against HEAD and both refs.
E01_IMAGE_METADATA_FILE="dist/e01-images.env"
E01_SMALL_IMAGE="registry.example.com/hooke/smoke-small@sha256:replace-with-64-hex-characters"
E01_LARGE_IMAGE="registry.example.com/hooke/smoke-large@sha256:replace-with-64-hex-characters"
E01_SMOKE_COMMAND_JSON='["/smoke-app"]'
E01_LIGHT_STARTUP_WORK_MIB="0"
E01_HEAVY_STARTUP_WORK_MIB="4096"

# In log mode, application timestamps are emitted inside the process, retained
# in container stdout, and imported by RUNTIME_EVENTS_EXPORT_HOOK; no inbound
# route from ACK Pods to the operator is needed. SDK mode sends the same events
# directly and requires a routable URL, non-empty token, and restricted firewall.
E01_APP_EVENT_MODE="log"
INGESTER_BIND_ADDRESS="127.0.0.1"
INGESTER_PORT="18080"
E01_INGESTER_REACHABLE_URL=""
HOOKE_AUTH_TOKEN=""

FIXED_NODE_SELECTOR_KEY="hooke.io/pool"
FIXED_NODE_SELECTOR_VALUE="fixed-cpu"
ELASTIC_NODE_SELECTOR_KEY="hooke.io/pool"
ELASTIC_NODE_SELECTOR_VALUE="elastic-cpu"
ELASTIC_TAINT_KEY="hooke.io/experiment"
ELASTIC_TAINT_VALUE="elastic"
ELASTIC_TAINT_EFFECT="NoSchedule"
CONFIRM_NEW_NODE_COLD_SOURCE="no"

E01_CPU_REQUEST="500m"
E01_CPU_LIMIT="1000m"
E01_MEMORY_REQUEST="256Mi"
E01_MEMORY_LIMIT="512Mi"
NODE_SCALE_TIMEOUT="20m"
E01_ELASTIC_ZERO_TIMEOUT="30m"
E01_PREWARM_TIMEOUT="15m"

# Hooks must use real node/runtime/SLS data. They receive the documented flags
# from scripts/ack-four-layer-baseline.sh and scripts/ack-first-smoke.sh.
# CACHE_RESET_HOOK removes only the exact target digest from matching fixed
# nodes; CACHE_VERIFY_HOOK proves warm/cold state without manufacturing events.
CACHE_RESET_HOOK="/absolute/path/to/cache-reset-hook"
CACHE_VERIFY_HOOK="/absolute/path/to/cache-verify-hook"
ACK_EVENTS_EXPORT_HOOK="/absolute/path/to/export-goatscaler-ndjson"
RUNTIME_EVENTS_EXPORT_HOOK="/absolute/path/to/export-runtime-events-ndjson"
ACK_ADAPTER_CONFIG="configs/ack-adapter.yaml"

# Privileged hooks use this already-cached utility image only to enter the host
# namespaces and invoke the node's journalctl/crictl/ctr. It must contain
# nsenter and be pullable by both fixed and newly provisioned nodes.
E01_HOST_HELPER_IMAGE="registry.example.com/ops/host-helper:immutable-version"
E01_CACHE_HOOK_TIMEOUT_SECONDS="120"
E01_CACHE_GC_WAIT_SECONDS="30"
E01_RUNTIME_HOOK_TIMEOUT_SECONDS="120"

# Stock ACK info-level journals expose an exact RunPodSandbox interval, but no
# separate UID-addressable CNI start/end pair. Keep this false unless a real CNI
# event source is configured; the exporter never fabricates that substage.
E01_REQUIRE_CNI_SUBSTAGE="false"

# Required by the GOATScaler SLS export hook. Use the control-plane logging
# project and ack-goatscaler Logstore for the selected ACK cluster.
ACK_SLS_REGION="cn-hangzhou"
ACK_SLS_PROJECT="k8s-log-replace-with-cluster-id"
ACK_SLS_LOGSTORE="ack-goatscaler-replace-with-cluster-id"
ACK_SLS_MAX_WAIT_SECONDS="30"

MYSQL_MODE="docker"
MYSQL_DOCKER_IMAGE="mysql:8.4"
MYSQL_CONTAINER_NAME="hooke-e01-mysql"
MYSQL_VOLUME_NAME="hooke-e01-mysql-data"
MYSQL_HOST_PORT="13306"
MYSQL_DATABASE="hooke"
MYSQL_USER="hooke"
MYSQL_PASSWORD="hooke"
MYSQL_ROOT_PASSWORD="root"
RESET_MYSQL="false"
STOP_MYSQL_ON_EXIT="false"

SKIP_BUILD="false"
GOPROXY=""
CONTROLLER_METRICS_PORT="18081"
CONTROLLER_WARMUP_SECONDS="5"
EVENT_SETTLE_SECONDS="5"
HOOKE_SYSTEM_NAMESPACE="hooke-system"
ENABLE_HTTP_CHECK="true"
CLEANUP_K8S_ON_SUCCESS="true"
CLEANUP_K8S_ON_ERROR="false"
REQUIRE_EMPTY_EXPERIMENT_NAMESPACE="true"
UNIQUE_EXPERIMENT_NAMESPACE="true"
UNIQUE_RESOURCE_NAMES="true"
DELETE_EXPERIMENT_NAMESPACE="true"
