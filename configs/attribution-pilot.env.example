# A01 GOATScaler task-ID attribution pilot.
# Copy this file to configs/attribution-pilot.env, then fill in the cluster
# identity, same-region immutable image digest, and elastic-pool selector.

CONFIRM_KUBE_CONTEXT="no"
EXPECTED_API_SERVER_SUBSTRING=""
KUBECONFIG_PATH="$HOME/.kube/config"
KUBE_CONTEXT=""
CLUSTER_ID="ack-attribution-pilot"

RUN_NAME_PREFIX="a01-attribution-g1"
SLO_SECONDS="30"
EXPERIMENT_NAMESPACE="hooke-attribution"
HOOKE_SYSTEM_NAMESPACE="hooke-system"
ARTIFACT_ROOT="artifacts"

SKIP_BUILD="false"
GOPROXY=""
INGESTER_PORT="18080"
CONTROLLER_METRICS_PORT="18081"
HOOKE_AUTH_TOKEN=""

MYSQL_MODE="docker"
MYSQL_DOCKER_IMAGE="mysql:8.4"
MYSQL_CONTAINER_NAME="hooke-smoke-mysql"
MYSQL_VOLUME_NAME="hooke-smoke-mysql-data"
MYSQL_HOST_PORT="13306"
MYSQL_DATABASE="hooke"
MYSQL_USER="hooke"
MYSQL_PASSWORD="hooke"
MYSQL_ROOT_PASSWORD="root"
RESET_MYSQL="false"
STOP_MYSQL_ON_EXIT="false"

# A01 isolates node attribution, so the fixed-node repetitions are disabled.
ENABLE_FIXED_SMOKE="false"
SMOKE_IMAGE="registry.example.com/hooke/smoke@sha256:replace-me"
SMOKE_IMAGE_PULL_POLICY="IfNotPresent"
SMOKE_CONTAINER_PORT="8080"
SMOKE_SERVICE_PORT="80"
SMOKE_READINESS_PATH="/readyz"
SMOKE_REQUEST_PATH="/work"
ENABLE_HTTP_CHECK="true"

ENABLE_NODE_SCALE_SMOKE="true"
NODE_SCALE_WORKLOAD_NAME="a01-wave1"
ELASTIC_NODE_SELECTOR_KEY="hooke.io/pool"
ELASTIC_NODE_SELECTOR_VALUE="elastic-cpu"
ELASTIC_TAINT_KEY="hooke.io/experiment"
ELASTIC_TAINT_VALUE="elastic"
ELASTIC_TAINT_EFFECT="NoSchedule"

# G1 default: one Pod -> one task -> one Node. Repeat this run five times after
# the pool returns to zero. Requests must fit one node while forcing scale-out.
NODE_SCALE_REPLICAS="1"
NODE_SCALE_CPU_REQUEST="1500m"
NODE_SCALE_CPU_LIMIT="2000m"
NODE_SCALE_MEMORY_REQUEST="256Mi"
NODE_SCALE_MEMORY_LIMIT="512Mi"
NODE_SCALE_TIMEOUT="20m"

# G3 enables a staggered second wave inside the same run. Use distinct requests
# when the instance allocatable capacity makes them distinguishable.
ENABLE_SECOND_NODE_SCALE_WAVE="false"
NODE_SCALE_SECOND_WORKLOAD_NAME="a01-wave2"
NODE_SCALE_SECOND_REPLICAS="1"
NODE_SCALE_SECOND_CPU_REQUEST="1000m"
NODE_SCALE_SECOND_CPU_LIMIT="1500m"
NODE_SCALE_SECOND_MEMORY_REQUEST="384Mi"
NODE_SCALE_SECOND_MEMORY_LIMIT="768Mi"
NODE_SCALE_WAVE_STAGGER_SECONDS="10"

REQUIRE_EMPTY_ELASTIC_POOL="true"
REQUIRE_NEW_NODE="true"
REQUIRE_NODE_UNSCHEDULABLE="true"
REQUIRE_TASK_ID_ATTRIBUTION="true"
ATTRIBUTION_WINDOW="10m"
EXPECTED_TASK_COUNT="1"
EXPECTED_MIN_PODS_PER_TASK="1"

# Optional exact ACK/ECS timestamps. Task-ID attribution still uses the Pod
# annotation and Node label when this is empty.
ACK_EVENTS_NDJSON=""
ACK_ADAPTER_CONFIG="configs/ack-adapter.yaml"

CLEANUP_K8S_ON_SUCCESS="true"
CLEANUP_K8S_ON_ERROR="false"
REQUIRE_EMPTY_EXPERIMENT_NAMESPACE="true"
UNIQUE_EXPERIMENT_NAMESPACE="true"
UNIQUE_RESOURCE_NAMES="true"
DELETE_EXPERIMENT_NAMESPACE="true"
