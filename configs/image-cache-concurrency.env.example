# E03 image size/cache/concurrency pilot. Copy to
# configs/image-cache-concurrency.env and replace every real placeholder.

# -------------------- target and safety --------------------
CONFIRM_KUBE_CONTEXT="no"
CONFIRM_E03_EXECUTION="no"
REQUIRE_CLEAN_GIT="true"
EXPECTED_API_SERVER_SUBSTRING="replace-with-ack-api-host-fragment"
KUBECONFIG_PATH="$HOME/.kube/config"
KUBE_CONTEXT=""
CLUSTER_ID="ack-e03-pilot"
HOOKE_SYSTEM_NAMESPACE="hooke-system"
ARTIFACT_ROOT="artifacts"

# -------------------- frozen pilot design --------------------
# One repetition is the code-path smoke: 27 cells. Increase only after that
# session passes. Existing nodes cover cold/warm; new nodes are cold-only
# because prewarming would make a "new+warm" observation semantically false.
E03_PILOT_REPETITIONS="1"
E03_RANDOM_SEED="20260723"
E03_MAX_TRIGGER_SPREAD_MS="1000"

# The stock journal exporter measures exact CRI PullImage start/end and bytes,
# but not a separate unpack interval. Keep false for pull-total E03-lite. Set
# true only after RUNTIME_EVENTS_EXPORT_HOOK emits real, build-id-bound
# IMAGE_UNPACK_START/END events. Strict summaries then separate download,
# unpack, and image-total latency; the Gate fails closed on missing samples.
E03_REQUIRE_UNPACK_SUBSTAGE="false"

# -------------------- immutable E03 images --------------------
# Build and push 12 images (3 sizes x 4 independent digests) with:
# make e03-images-push IMAGE_REPOSITORY=<same-region-acr-repository>
E03_IMAGE_METADATA_FILE="dist/e03-images.env"
E03_IMAGE_REGISTRY_HOST="registry.example.com"

# -------------------- node controls --------------------
# Existing cells are pinned to this exact Ready node with
# kubernetes.io/hostname. Existing and new nodes must use the same instance
# type and zone so the node factor does not silently absorb a hardware change.
# Both targets must allow parallel image pulls for concurrency 2/4. The
# validator measures positive-duration PullImage overlap and fails if the
# kubelet/runtime serializes the requested batch.
E03_EXISTING_NODE_NAME="replace-with-exact-node-name"
E03_EXPECTED_INSTANCE_TYPE="ecs.c7.large"
E03_EXPECTED_ZONE="cn-example-a"

# Operator-frozen disk category recorded in every observation. Populate this
# from the ACK node-pool/ECS disk configuration, not from an assumption.
E03_DISK_TYPE="cloud_essd"

# Optional taint on the existing target. Leave both values empty if none.
FIXED_TAINT_KEY=""
FIXED_TAINT_VALUE=""
FIXED_TAINT_EFFECT="NoSchedule"

# The elastic selector must identify a dedicated min=0 pool. Resource requests
# for four Pods must fit one node; post-run Gate requires one new Node and all
# Pods scheduled on it.
ELASTIC_NODE_SELECTOR_KEY="node.alibabacloud.com/nodepool-id"
ELASTIC_NODE_SELECTOR_VALUE="replace-with-nodepool-id"
ELASTIC_TAINT_KEY="hooke.io/experiment"
ELASTIC_TAINT_VALUE="elastic"
ELASTIC_TAINT_EFFECT="NoSchedule"
CONFIRM_NEW_NODE_COLD_SOURCE="no"

# -------------------- workload --------------------
E03_SMOKE_COMMAND_JSON='["/smoke-app"]'
E03_STARTUP_WORK_MIB="0"
E03_CPU_REQUEST="100m"
E03_CPU_LIMIT="500m"
E03_MEMORY_REQUEST="128Mi"
E03_MEMORY_LIMIT="256Mi"

E03_APP_EVENT_MODE="log"
E03_INGESTER_REACHABLE_URL=""
INGESTER_BIND_ADDRESS="127.0.0.1"
INGESTER_PORT="18080"
CONTROLLER_METRICS_PORT="18081"
HOOKE_AUTH_TOKEN=""

# -------------------- exact evidence hooks --------------------
CACHE_RESET_HOOK="scripts/e01-cache-hook.py"
CACHE_VERIFY_HOOK="scripts/e01-cache-hook.py"
ACK_EVENTS_EXPORT_HOOK="scripts/export-goatscaler-events.py"
RUNTIME_EVENTS_EXPORT_HOOK="scripts/export-runtime-journal-events.py"
ACK_ADAPTER_CONFIG="configs/ack-adapter.yaml"

E01_HOST_HELPER_IMAGE="registry.example.com/ops/host-helper:immutable-version"
E01_CACHE_HOOK_TIMEOUT_SECONDS="120"
E01_CACHE_GC_WAIT_SECONDS="30"
E01_RUNTIME_HOOK_TIMEOUT_SECONDS="300"

ACK_SLS_REGION="cn-example"
ACK_SLS_PROJECT="k8s-log-replace-with-cluster-id"
ACK_SLS_LOGSTORE="ack-goatscaler-replace-with-cluster-id"
ACK_SLS_MAX_WAIT_SECONDS="30"

# -------------------- timeouts and local services --------------------
E03_CACHE_HOOK_TIMEOUT_SECONDS="600"
E03_CHILD_RUN_TIMEOUT_SECONDS="7200"
E03_ELASTIC_ZERO_TIMEOUT_SECONDS="2400"
E03_ELASTIC_POLL_SECONDS="15"
E03_PREWARM_TIMEOUT_SECONDS="1800"
NODE_SCALE_TIMEOUT="30m"
ROLLOUT_TIMEOUT="20m"
CONTROLLER_WARMUP_SECONDS="5"
EVENT_SETTLE_SECONDS="5"

MYSQL_MODE="docker"
MYSQL_DOCKER_IMAGE="mysql:8.4"
MYSQL_CONTAINER_NAME="hooke-e03-mysql"
MYSQL_VOLUME_NAME="hooke-e03-mysql-data"
MYSQL_HOST_PORT="13306"
MYSQL_DATABASE="hooke"
MYSQL_USER="hooke"
MYSQL_PASSWORD="hooke"
MYSQL_ROOT_PASSWORD="root"
MYSQL_DSN=""
MYSQL_CLI_HOST=""
MYSQL_CLI_PORT="3306"
MYSQL_CLI_USER=""
MYSQL_CLI_PASSWORD=""
RESET_MYSQL="false"
STOP_MYSQL_ON_EXIT="false"

SKIP_BUILD="false"
GOPROXY=""
ENABLE_HTTP_CHECK="true"
CLEANUP_K8S_ON_SUCCESS="true"
CLEANUP_K8S_ON_ERROR="true"
REQUIRE_EMPTY_EXPERIMENT_NAMESPACE="true"
UNIQUE_EXPERIMENT_NAMESPACE="true"
UNIQUE_RESOURCE_NAMES="true"
DELETE_EXPERIMENT_NAMESPACE="true"
