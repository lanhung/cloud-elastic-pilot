# Hooke ACK first smoke configuration.
# This profile runs only the fixed-node smoke test. Node-scale smoke is disabled.

# ACK / kubeconfig safety guardrails.
CONFIRM_KUBE_CONTEXT="yes"
EXPECTED_API_SERVER_SUBSTRING="8.130.169.28"
KUBECONFIG_PATH="$HOME/.kube/config"
KUBE_CONTEXT="kubernetes-admin-c061d99ce379f4e37a9ff97e027a36ca6"
CLUSTER_ID="c061d99ce379f4e37a9ff97e027a36ca6"

# Experiment metadata.
RUN_NAME_PREFIX="first-smoke"
SLO_SECONDS="30"
EXPERIMENT_NAMESPACE="hooke-experiments-scale"
HOOKE_SYSTEM_NAMESPACE="hooke-system"

# Build and local processes.
SKIP_BUILD="false"
GOPROXY="https://goproxy.cn,direct"
INGESTER_PORT="18080"
CONTROLLER_METRICS_PORT="18081"
HOOKE_AUTH_TOKEN=""
CONTROLLER_WARMUP_SECONDS="5"
EVENT_SETTLE_SECONDS="5"
ARTIFACT_ROOT="artifacts"

# Local MySQL. Existing data is preserved.
MYSQL_MODE="docker"
MYSQL_DOCKER_IMAGE="mysql:8.4"
MYSQL_CONTAINER_NAME="hooke-smoke-mysql"
MYSQL_VOLUME_NAME="hooke-smoke-mysql-data"
MYSQL_HOST_PORT="13306"
MYSQL_DATABASE="hooke"
MYSQL_USER="hooke"
MYSQL_PASSWORD="hooke"
MYSQL_ROOT_PASSWORD="root"
RESET_MYSQL="false"
STOP_MYSQL_ON_EXIT="false"

# Fixed-node smoke test.
SMOKE_WORKLOAD_NAME="hooke-smoke-app"
SMOKE_IMAGE="registry.cn-hangzhou.aliyuncs.com/google_containers/echoserver:1.10"
SMOKE_IMAGE_PULL_POLICY="IfNotPresent"
SMOKE_CONTAINER_PORT="8080"
SMOKE_SERVICE_PORT="80"
SMOKE_READINESS_PATH="/"
SMOKE_REQUEST_PATH="/"
SMOKE_DISABLE_SDK="true"
SMOKE_CPU_REQUEST="100m"
SMOKE_CPU_LIMIT="500m"
SMOKE_MEMORY_REQUEST="64Mi"
SMOKE_MEMORY_LIMIT="256Mi"
SMOKE_REPETITIONS="3"
ROLLOUT_TIMEOUT="5m"
ENABLE_HTTP_CHECK="true"
FIXED_NODE_SELECTOR_KEY=""
FIXED_NODE_SELECTOR_VALUE=""

# Node-scale smoke. The existing ACK node pool has autoscaling enabled with
# min=1/max=5. Three 1500m Pods fit one per current node and force one more
# node under the currently observed resource requests.
ENABLE_NODE_SCALE_SMOKE="false"
NODE_SCALE_WORKLOAD_NAME="hooke-node-scale-smoke"
ELASTIC_NODE_SELECTOR_KEY="node.alibabacloud.com/nodepool-id"
ELASTIC_NODE_SELECTOR_VALUE="np1e64fc46fb0948019f59df32ec7a52b1"
ELASTIC_TAINT_KEY=""
ELASTIC_TAINT_VALUE=""
ELASTIC_TAINT_EFFECT=""
NODE_SCALE_REPLICAS="3"
NODE_SCALE_CPU_REQUEST="1500m"
NODE_SCALE_CPU_LIMIT="2000m"
NODE_SCALE_MEMORY_REQUEST="256Mi"
NODE_SCALE_MEMORY_LIMIT="512Mi"
NODE_SCALE_TIMEOUT="20m"
REQUIRE_EMPTY_ELASTIC_POOL="false"
REQUIRE_NEW_NODE="true"
REQUIRE_NODE_UNSCHEDULABLE="true"

# Cleanup policy. Preserve the namespace and local database for inspection.
CLEANUP_K8S_ON_SUCCESS="true"
CLEANUP_K8S_ON_ERROR="true"
REQUIRE_EMPTY_EXPERIMENT_NAMESPACE="true"
UNIQUE_RESOURCE_NAMES="true"
DELETE_EXPERIMENT_NAMESPACE="false"
