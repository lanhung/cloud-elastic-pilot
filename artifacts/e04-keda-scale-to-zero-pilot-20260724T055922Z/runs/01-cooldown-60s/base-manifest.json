          "hooke.io/experiment": "E04"
        },
        "name": "redis",
        "namespace": "e04-1-01ky9ban"
      },
      "spec": {
        "replicas": 1,
        "selector": {
          "matchLabels": {
            "hooke.io/e04-role": "redis",
            "hooke.io/experiment": "E04"
          }
        },
        "template": {
          "metadata": {
            "annotations": {
              "hooke.io/run-id": "01KY9BANFE1BTC4WWVFJSDTYRT"
            },
            "labels": {
              "hooke.io/e04-role": "redis",
              "hooke.io/experiment": "E04"
            }
          },
          "spec": {
            "automountServiceAccountToken": false,
            "containers": [
              {
                "command": [
                  "sh",
                  "-c",
                  "exec redis-server --appendonly no --save \"\" --requirepass \"$E04_REDIS_PASSWORD\""
                ],
                "env": [
                  {
                    "name": "E04_REDIS_PASSWORD",
                    "valueFrom": {
                      "secretKeyRef": {
                        "key": "password",
                        "name": "redis-auth"
                      }
                    }
                  }
