                "name": "redis",
                "ports": [
                  {
                    "containerPort": 6379,
                    "name": "redis"
                  }
                ],
                "readinessProbe": {
                  "exec": {
                    "command": [
                      "sh",
                      "-c",
                      "test \"$(REDISCLI_AUTH=\"$E04_REDIS_PASSWORD\" redis-cli -h 127.0.0.1 ping)\" = PONG"
                    ]
                  },
                  "failureThreshold": 60,
                  "periodSeconds": 1,
                  "timeoutSeconds": 1
                },
                "resources": {
                  "limits": {
                    "cpu": "500m",
                    "memory": "256Mi"
                  },
                  "requests": {
                    "cpu": "100m",
                    "memory": "128Mi"
                  }
                },
                "securityContext": {
                  "allowPrivilegeEscalation": false,
                  "capabilities": {
                    "drop": [
                      "ALL"
                    ]
                  },
                  "runAsGroup": 999,
                  "runAsNonRoot": true,
                  "runAsUser": 999
                },
                "volumeMounts": [
                  {
                    "mountPath": "/data",
                    "name": "data"
                  }
                ]
              }
            ],
            "nodeSelector": {
              "kubernetes.io/hostname": "cn-wulanchabu.10.170.108.83"
            },
            "securityContext": {
              "fsGroup": 999,
              "runAsGroup": 999,
              "runAsNonRoot": true,
              "runAsUser": 999
            },
            "terminationGracePeriodSeconds": 10,
            "volumes": [
              {
                "emptyDir": {},
                "name": "data"
              }
            ]
          }
        }
      }
